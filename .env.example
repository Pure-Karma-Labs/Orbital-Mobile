# Orbital Mobile — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# WARNING: Only mobile app config belongs here. Do NOT put backend
# secrets (DATABASE_URL, JWT_SECRET, etc.) in this file — react-native-config
# bundles ALL .env values into the native binary.
#
# LOCAL SMOKE TESTING
# Two pre-built profiles are committed for pointing debug builds at a local
# Docker backend stack (see Orbital-Backend/docs/LOCAL-SMOKE.md):
#   .env.smoke.android — uses http://10.0.2.2:3000 (Android emulator host alias)
#   .env.smoke.ios     — uses http://localhost:3000 (iOS simulator shares host network)
#
# Run with:
#   npm run android:smoke    # Android emulator → local stack
#   npm run ios:smoke        # iOS simulator   → local stack
#
# These are debug-only. Release builds enforce HTTPS and will refuse to start
# with an http:// API_URL (enforced in src/config/env.ts).

# Sentry DSN — error monitoring. Leave blank to disable Sentry.
SENTRY_DSN=

# API base URL — the Orbital backend. Defaults to http://localhost:3000 in dev.
API_URL=https://api.orbitl.org
