# Orbital Mobile — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# WARNING: Only mobile app config belongs here. Do NOT put backend
# secrets (DATABASE_URL, JWT_SECRET, etc.) in this file — react-native-config
# bundles ALL .env values into the native binary.

# Sentry DSN — error monitoring. Leave blank to disable Sentry.
SENTRY_DSN=

# API base URL — the Orbital backend. Defaults to http://localhost:3000 in dev.
API_URL=https://api.orbitl.org
