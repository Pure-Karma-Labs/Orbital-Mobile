{
  "name": "orbital-mobile",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pure-Karma-Labs/Orbital-Mobile.git"
  },
  "scripts": {
    "android": "react-native run-android",
    "android:smoke": "ENVFILE=.env.smoke.android react-native run-android",
    "ios": "react-native run-ios",
    "ios:smoke": "rm -f /tmp/envfile && ENVFILE=.env.smoke.ios react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build:rust:ios": "cd packages/orbital-signal && npm run build:ios && cd ../../ios && pod install",
    "build:rust:android": "cd packages/orbital-signal && npm run build:android",
    "build:rust": "npm run build:rust:ios && npm run build:rust:android",
    "build:rust:ios:release": "cd packages/orbital-signal && npm run build:ios:release && cd ../../ios && pod install",
    "build:rust:android:release": "cd packages/orbital-signal && npm run build:android:release",
    "build:rust:release": "npm run build:rust:ios:release && npm run build:rust:android:release",
    "security:invariants": "node scripts/check-security-invariants.mjs",
    "generate:emoji": "node scripts/generate-emoji-assets.mjs",
    "test:rust-gate:android": "bash scripts/test-rust-profile-gate-android.sh",
    "test:rust-gate:ios": "bash scripts/test-rust-profile-gate-ios.sh"
  },
  "dependencies": {
    "@dr.pogodin/react-native-fs": "^2.39.2",
    "@notifee/react-native": "^9.1.8",
    "@op-engineering/op-sqlite": "^17.1.2",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.17.10",
    "@sentry/react-native": "^8.17.2",
    "emoji-datasource": "^16.0.0",
    "fuse.js": "^7.4.2",
    "orbital-signal": "file:./packages/orbital-signal",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-bootsplash": "^7.3.2",
    "react-native-compressor": "2.0.2",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-dynamic-import": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.2",
    "@react-native-community/cli-platform-android": "20.0.2",
    "@react-native-community/cli-platform-ios": "20.0.2",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/new-app-screen": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "3.9.6",
    "react-test-renderer": "19.1.1",
    "openmoji": "^17.0.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "op-sqlite": {
    "sqlcipher": true,
    "fts5": true
  }
}
